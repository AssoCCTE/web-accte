---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Web ACCTE">
  <main class="page-shell">
    <section class="hero" aria-labelledby="hero-title">
      <p class="eyebrow">Astro minimal</p>
      <h1 id="hero-title">Un site statique, rapide et sans framework JavaScript.</h1>
      <p class="intro">
        Cette base privilégie le HTML généré au build, le CSS simple et aucun
        JavaScript côté client par défaut.
      </p>
      <a class="button" href="https://astro.build" rel="noreferrer">Découvrir Astro</a>
    </section>
  </main>
</BaseLayout>
