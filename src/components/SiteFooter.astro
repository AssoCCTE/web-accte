---
import IconEmail from "./icons/IconEmail.astro";
import IconInstagram from "./icons/IconInstagram.astro";
import IconLinkedIn from "./icons/IconLinkedIn.astro";
import { site } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__name">{site.fullName}</p>
      <p class="site-footer__copy">&copy; {year} {site.name}</p>
    </div>

    <div class="site-footer__contact">
      <h2 class="site-footer__heading">Contact</h2>
      <a
        class="site-footer__link site-footer__link--icon"
        href={`mailto:${site.contactEmail}`}
      >
        <IconEmail />
        <span>{site.contactEmail}</span>
      </a>
    </div>

    <div class="site-footer__social">
      <h2 class="site-footer__heading">Réseaux sociaux</h2>
      <ul class="site-footer__social-list">
        <li>
          <a
            class="site-footer__link site-footer__link--icon"
            href={site.social.linkedin}
            rel="noopener noreferrer"
            target="_blank"
          >
            <IconLinkedIn />
            <span>LinkedIn</span>
          </a>
        </li>
        <li>
          <a
            class="site-footer__link site-footer__link--icon"
            href={site.social.instagram}
            rel="noopener noreferrer"
            target="_blank"
          >
            <IconInstagram />
            <span>Instagram</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
